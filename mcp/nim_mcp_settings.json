{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": false
    },
    "memory": {
      "command": "uv",
      "args": ["run", "--directory", "${GRAPHITI_MCP_DIR}", "graphiti_mcp"],
      "env": {
        "GRAPHITI_CONFIG_PATH": "${GRAPHITI_CONFIG}"
      },
      "disabled": false
    }
  }
}
