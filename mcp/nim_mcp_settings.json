{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": false
    },
    "memory": {
      "command": "uv",
      "args": ["run", "--directory", "${GRAPHITI_MCP_DIR}", "python", "main.py", "--config", "${GRAPHITI_CONFIG}", "--transport", "stdio"],
      "env": {
        "OPENAI_API_KEY": "ollama",
        "OPENAI_BASE_URL": "http://localhost:11434/v1"
      },
      "disabled": false
    }
  }
}
